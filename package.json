{
  "name": "homebridge-mnet-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for homebridge-mnet v2 and the g50a-client protocol library.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "^22.10.0 || ^24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint packages",
    "format": "prettier --write \"packages/**/*.{ts,json,md}\"",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
